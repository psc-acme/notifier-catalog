{
    "name": "psc-acme/notifier-catalog",
    "description": "Package notifier-catalog for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\NotifierCatalog\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "brick/date-time": "^0.7.1",
        "illuminate/support": "^11.0",
        "doctrine/doctrine-bundle": "^2.13",
        "symfony/event-dispatcher": "^7.0",
        "webmozart/assert": "^1.0",
        "vlucas/phpdotenv": "^5.0"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan-symfony": "^1.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}